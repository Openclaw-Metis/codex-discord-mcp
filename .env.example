DISCORD_BOT_TOKEN=replace-with-your-discord-bot-token

# Optional. Defaults to ~/.codex/discord.
# CODEX_DISCORD_STATE_DIR=C:\Users\you\.codex\discord

# Optional relay settings for `codex-discord-mcp bot`.
# CODEX_COMMAND=codex
# CODEX_WORKDIR=C:\path\to\repo
# CODEX_SANDBOX=read-only
# CODEX_APPROVAL_POLICY=never
# CODEX_MODEL=
# CODEX_PROFILE=
# CODEX_RESUME_BY_CHANNEL=false
# CODEX_TIMEOUT_MS=900000

# Optional path list for files the bridge is allowed to upload as Discord attachments.
# Defaults to process cwd, CODEX_WORKDIR, and the bridge inbox.
# Codex's image_gen output dir is always allowed in addition to these.
# CODEX_DISCORD_ATTACHMENT_ROOTS=C:\path\to\repo;C:\path\to\exports

# Optional. Where Codex's built-in image_gen saves files. Surfaced by the
# latest_generated_images MCP tool and always allowed for attachments.
# Defaults to ~/.codex/generated_images.
# CODEX_DISCORD_GENERATED_IMAGES_DIR=/home/you/.codex/generated_images
