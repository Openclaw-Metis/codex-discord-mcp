{
  "name": "codex-discord-mcp",
  "version": "0.1.0",
  "description": "Discord bot bridge and MCP tools for Codex CLI.",
  "type": "module",
  "bin": {
    "codex-discord-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:mcp": "tsx src/cli.ts mcp",
    "dev:bot": "tsx src/cli.ts bot",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "cross-spawn": "^7.0.6",
    "discord.js": "^14.18.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
